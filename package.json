{
  "name": "villa-laura-site",
  "version": "1.0.0",
  "description": "Static guest-support site for Villa Laura in Sardinia",
  "main": "index.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "preview": "npx serve dist",
    "check": "npm run build && npm test && npm run security:scan",
    "test": "node --test tests",
    "test:e2e": "playwright test",
    "security:scan": "node scripts/security-scan.mjs",
    "dev:pages": "npx wrangler pages dev dist --compatibility-date=2026-05-02"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaotovolli/Villa-Laura.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/joaotovolli/Villa-Laura/issues"
  },
  "homepage": "https://github.com/joaotovolli/Villa-Laura#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.55.1",
    "serve": "^14.2.6",
    "sharp": "^0.34.5"
  },
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  }
}
